{
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "frontend/dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/index.py"
        },
        {
            "source": "/accounts/(.*)",
            "destination": "/index.py"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/index.py"
        },
        {
            "source": "/static/django/(.*)",
            "destination": "/index.py"
        },
        {
            "source": "/media/(.*)",
            "destination": "/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}