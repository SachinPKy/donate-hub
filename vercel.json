{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "app.py"
        },
        {
            "src": "/admin/(.*)",
            "dest": "app.py"
        },
        {
            "src": "/static/django/(.*)",
            "dest": "app.py"
        },
        {
            "src": "/media/(.*)",
            "dest": "app.py"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/package.json"
        }
    ]
}